<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deezer API + MP3 download -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Set system ringtone -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />

    <!-- Audio file access (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Notifications for ringtone changes -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- WorkManager: keep scheduled tasks alive -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Per-contact ringtone -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!-- EVERY_CALL: ringtone wisselen na elk gesprek -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Beller-info ophalen bij inkomend gesprek (Android 10+) -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- In-app APK installatie -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RandomRingtone">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RandomRingtone">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- NotificationListenerService voor SMS/WhatsApp custom ringtones -->
        <service
            android:name=".service.NotificationService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- FileProvider voor in-app APK installatie -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- CallStateReceiver: ringtone wisselen na elk gesprek (EVERY_CALL) -->
        <receiver
            android:name=".receiver.CallStateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
